## Example environment file (DO NOT put real secrets here)

# MySQL (recommended)
MYSQL_HOST=your-db-host
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=REPLACE_ME
MYSQL_DATABASE=zeabur

# Also supported: DB_HOST / DB_PORT / DB_USER / DB_PASSWORD / DB_NAME
# Zeabur often exposes MYSQL_URI for linked MySQL services
# Alternatively (optional): provide a single connection string
# DATABASE_URL=mysql://root:REPLACE_ME@your-db-host:3306/zeabur
# MYSQL_URI=mysql://root:REPLACE_ME@your-db-host:3306/zeabur

# App
NODE_ENV=production
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRE=7d
ALLOWED_ORIGINS=https://gpstask.zeabur.app,http://localhost:3000

# Plant RAG: 單張照片模式（只用第1張圖，不要求補拍，可減少多圖聚合雜訊）
# SINGLE_PHOTO_MODE=1

# AI (OpenAI-compatible Chat Completions endpoint)
# - LM Studio (local): http://localhost:1234/v1  (API key can be any string, e.g. "lm-studio")
# - OpenAI: https://api.openai.com/v1 (set AI_API_KEY to your OpenAI key)
# - 自行部署 Gemma: 請使用對應的 OpenAI-compatible endpoint，並將 AI_MODEL 設為 google/gemma-3-27b
AI_API_URL=http://localhost:1234/v1
AI_API_KEY=lm-studio
AI_MODEL=google/gemma-3-27b

